rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper to check for Somatone domain
    function isSomatoneUser() {
      return isAuthenticated() && request.auth.token.email.split('@')[1] == 'somatone.com';
    }

    // Helper to check for Admin role (reads from the user document)
    function isAdmin() {
      return isSomatoneUser() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Users collection
    match /users/{userId} {
      allow read: if isSomatoneUser();
      // Allow users to write their own profile
      allow write: if isSomatoneUser() && request.auth.uid == userId;
    }

    // Clients collection
    match /clients/{clientId} {
      allow read: if isSomatoneUser();
      allow write: if isAdmin(); // Only admins can manage clients
    }

    // Projects collection
    match /projects/{projectId} {
      allow read: if isSomatoneUser();
      allow write: if isSomatoneUser(); // Members can manage projects/tickets

      // Tickets subcollection
      match /tickets/{ticketId} {
        allow read: if isSomatoneUser();
        allow write: if isSomatoneUser();
      }
    }
  }
}
